## Frontend env
#
# Optional for local/proxy testing; in production use relative /api/lead.
# VUE_APP_API_BASE_URL=http://localhost:3000
VUE_APP_API_BASE_URL=

## Server env (set these in Vercel Project -> Settings -> Environment Variables)
# GoHighLevel base URL
GHL_BASE_URL=https://services.leadconnectorhq.com

# Private Integration Token (Sub-Account) OR OAuth access token
GHL_API_KEY=REPLACE_ME

# Your GoHighLevel Location (Sub-Account) ID
GHL_LOCATION_ID=REPLACE_ME

# Comma-separated tags to apply
GHL_TAGS=Website Form

# Optional: map form keys to GHL custom-field IDs as JSON.
# Example:
# GHL_CUSTOM_FIELD_IDS={"fundType":"BcdmQEsNgz6AVpgLVUJ0","howCanWeWorkTogether":"abc123"}
GHL_CUSTOM_FIELD_IDS=